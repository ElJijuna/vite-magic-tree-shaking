{
  "name": "vite-magic-tree-shaking",
  "version": "0.1.0",
  "description": "Auto-generate tree-shakeable lib entries for Vite build.lib.entry",
  "author": "pilmee",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ElJijuna/vite-magic-tree-shaking.git"
  },
  "bugs": {
    "url": "https://github.com/ElJijuna/vite-magic-tree-shaking/issues"
  },
  "homepage": "https://github.com/ElJijuna/vite-magic-tree-shaking#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "vite-magic": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc --options typedoc.config.cjs"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^25.5.2",
    "semantic-release": "^24.2.9",
    "typedoc": "^0.28.18",
    "typescript": "^5.4.0",
    "vite": "^8.0.3",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "keywords": [
    "vite",
    "tree-shaking",
    "lib",
    "entry",
    "build"
  ]
}