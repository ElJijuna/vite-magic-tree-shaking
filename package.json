{
  "name": "vite-magic-tree-shaking",
  "version": "1.1.0",
  "description": "Auto-generate tree-shakeable lib entries for Vite build.lib.entry",
  "author": "pilmee <pilmee@gmail.com> (https://github.com/ElJijuna)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ElJijuna/vite-magic-tree-shaking.git"
  },
  "bugs": {
    "url": "https://github.com/ElJijuna/vite-magic-tree-shaking/issues"
  },
  "homepage": "https://github.com/ElJijuna/vite-magic-tree-shaking#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "vite-magic": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "check": "npm run lint && npm run format:check && npm run markdown:check && npm run typecheck && npm test && npm run build && npm run package:check",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "markdown:check": "node scripts/check-markdown.mjs",
    "commitlint": "commitlint --from HEAD~1 --to HEAD --verbose",
    "package:check": "node scripts/check-package.mjs",
    "docs": "typedoc --options typedoc.json"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@semantic-release/changelog": "^7.0.0",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^11.0.0",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "markdownlint": "^0.41.1",
    "semantic-release": "^25.0.8",
    "super-configs": "^1.19.0",
    "typedoc": "^0.28.20",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "vite": ">=5.0.0 <9.0.0"
  },
  "keywords": [
    "vite",
    "tree-shaking",
    "lib",
    "entry",
    "build"
  ]
}
